# PostgreSQL
POSTGRES_USER=horse
POSTGRES_PASSWORD=horse
POSTGRES_DB=horse_racing

# アプリのDB接続文字列（上のPOSTGRES_* と整合させること）
DATABASE_URL=postgresql+psycopg2://horse:horse@db:5432/horse_racing

# 賭けモード: prod(本番) / sim(シミュレーション)
# ※ 賭けモード・賭け金額・閾値・期待値は管理コンソール(http://localhost:8000)の
#    「設定」からも変更でき、そちらの値が優先される(再起動不要)
BETTING_MODE=sim

# 各定期ジョブの実行間隔（分）
COLLECT_INTERVAL_MINUTES=60
PREDICT_INTERVAL_MINUTES=30

# 何日先のレースまで収集するか（JRAは主に土日開催のため、平日も先読みして収集する）
COLLECT_DAYS_AHEAD=3

# 賭け判断を行うのは発走何分前から先か（古いオッズでの賭けを避けるため発走直前に限定）
BET_WINDOW_MINUTES=60

# 賭け戦略: 1件あたりの賭け金額(円、100円単位) / 賭けを行う予測スコアの下限(0-1)
BET_AMOUNT=100
BET_SCORE_THRESHOLD=0.15

# 賭けを行う期待値(予測スコア×単勝オッズ)の下限。1.0=モデル上プラス期待値の時のみ賭ける
BET_MIN_EXPECTED_VALUE=1.0

# netkeibaへのリクエスト間隔(秒)。サイトへの負荷軽減のため1秒以上を推奨
SCRAPER_REQUEST_INTERVAL_SECONDS=1

# IPAT(JRA即時購入)自動操作に使用する認証情報
# 加入者番号(8桁) / 暗証番号(4桁) / P-ARS番号(4桁)
IPAT_SUBSCRIBER_NUMBER=
IPAT_PIN=
IPAT_PARS_NUMBER=

# true の間は購入確認画面まで遷移してログ出力のみ行い、実際の購入ボタンは押さない。
# 実購入を有効にする前に、必ずIPATの画面構成・セレクタを実機で確認すること。
IPAT_DRY_RUN=true
