# PostgreSQL
POSTGRES_USER=horse
POSTGRES_PASSWORD=horse
POSTGRES_DB=horse_racing
DATABASE_URL=postgresql+psycopg2://horse:horse@db:5432/horse_racing

# Betting mode: sim or prod.
# Betting mode, amount, thresholds, and schedule settings can also be changed from the WebUI.
BETTING_MODE=sim

# Scheduled interval jobs, in minutes.
COLLECT_INTERVAL_MINUTES=60
PREDICT_INTERVAL_MINUTES=30
COLLECT_HORSES_INTERVAL_MINUTES=1440
COLLECT_JOCKEYS_INTERVAL_MINUTES=1440
COLLECT_TRAINERS_INTERVAL_MINUTES=1440
TRAIN_INTERVAL_MINUTES=43200

# Race collection.
COLLECT_DAYS_AHEAD=3

# Race-start based jobs.
# bet_decide runs before race start; settle runs after race start.
BET_DECISION_WINDOW_MINUTES=60
BET_DECISION_LEAD_MINUTES=10
SETTLE_DELAY_MINUTES=20

# Betting strategy.
BET_AMOUNT=100
BET_SCORE_THRESHOLD=0.15
BET_MIN_EXPECTED_VALUE=1.0

# Scraping.
SCRAPER_REQUEST_INTERVAL_SECONDS=1
HORSE_RESULTS_PER_RUN=30
HORSE_RESULTS_REFRESH_DAYS=30
JOCKEY_RESULTS_PER_RUN=30
JOCKEY_RESULTS_REFRESH_DAYS=30
TRAINER_RESULTS_PER_RUN=30
TRAINER_RESULTS_REFRESH_DAYS=30

# IPAT production purchase credentials.
IPAT_SUBSCRIBER_NUMBER=
IPAT_PIN=
IPAT_PARS_NUMBER=

# Keep true until the real IPAT purchase flow is verified on the actual machine.
IPAT_DRY_RUN=true

# WebUI admin login.
ADMIN_LOGIN_ID=admin
ADMIN_PASSWORD=change-me
